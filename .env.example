# Neon Postgres (required)
DATABASE_URI=postgresql://user:password@host/db?sslmode=require

# Payload auth secret — generate a long random string (required)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Vercel Blob — auto-set when Blob storage is added to the Vercel project (production media)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: email for contact forms (Resend / SMTP — see send-email route)
# RESEND_API_KEY=
