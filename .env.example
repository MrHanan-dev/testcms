# ============================================
# DATABASE (Required)
# ============================================
# Neon Postgres connection string
DATABASE_URI=postgresql://user:password@host:5432/database?sslmode=require

# ============================================
# PAYLOAD CMS (Required)
# ============================================
# Auth secret — generate a long random string (min 32 characters)
PAYLOAD_SECRET=your-secure-secret-min-32-chars

# ============================================
# SITE URL (Required for production)
# ============================================
# Your production domain (used for SEO, redirects, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================
# VERCEL BLOB STORAGE (Required for production media uploads)
# ============================================
# WITHOUT THIS, ALL IMAGE UPLOADS WILL FAIL ON VERCEL!
#
# How to set up:
# 1. Go to Vercel Dashboard → your project → Storage tab
# 2. Click "Create Database" → select "Blob"
# 3. Follow the prompts to create a Blob store
# 4. Link it to your project — this auto-sets BLOB_READ_WRITE_TOKEN
# 5. Redeploy the project
#
# Get this from: Vercel Dashboard > Storage > Create Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxx

# ============================================
# API SECURITY SECRETS (Required in production)
# ============================================
# These protect sensitive API endpoints. Generate unique random strings.
# Without them, the corresponding endpoints will return 500 errors.

# Protects /api/cron/publish-scheduled (required for scheduled posts)
CRON_SECRET=generate-a-random-string

# Protects /api/backup (required for data export/import)
BACKUP_SECRET=generate-a-random-string

# Protects /api/export (required for content export)
EXPORT_SECRET=generate-a-random-string

# Protects /api/cache (required for cache management)
CACHE_SECRET=generate-a-random-string

# Optional: Protects /api/health detailed info (recommended)
HEALTH_SECRET=generate-a-random-string

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Option 1: Gmail (for contact forms via /api/send-email)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# Option 2: Resend (for CMS notifications)
# RESEND_API_KEY=re_xxxxx

# Where to send form/lead notifications
# NOTIFICATION_EMAIL=notifications@yourdomain.com

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================
# reCAPTCHA for form protection
# RECAPTCHA_SITE_KEY=your-site-key
# RECAPTCHA_SECRET_KEY=your-secret-key

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to "true" to allow Payload to push schema changes
# PAYLOAD_DB_PUSH=true
