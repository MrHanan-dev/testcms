# =============================================================================
# REQUIRED FOR VERCEL DEPLOYMENT
# =============================================================================

# Neon Postgres connection string (required)
DATABASE_URI=postgresql://user:password@host/db?sslmode=require

# Payload auth secret — generate a long random string (required)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Site URL — set to your Vercel deployment URL (required for redirects/SEO)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# =============================================================================
# VERCEL BLOB STORAGE — REQUIRED FOR IMAGE UPLOADS
# =============================================================================
# Without this, ALL image uploads in the CMS will fail on Vercel!
# 
# How to set up:
# 1. Go to Vercel Dashboard → your project → Storage tab
# 2. Click "Create Database" → select "Blob"
# 3. Follow the prompts to create a Blob store
# 4. Link it to your project — this auto-sets BLOB_READ_WRITE_TOKEN
# 5. Redeploy the project
#
BLOB_READ_WRITE_TOKEN=

# =============================================================================
# OPTIONAL
# =============================================================================

# Email for contact/booking forms (choose one)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password
# OR
# RESEND_API_KEY=re_...

# Secure the scheduled publish cron endpoint
# CRON_SECRET=your-random-secret

# Where to send lead/comment notifications
# NOTIFICATION_EMAIL=admin@theagilenest.com
