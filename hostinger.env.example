# Import this file in Hostinger → Settings and redeploy → Environment variables → Import .env
# Replace every placeholder with your real values (same as Vercel / .env.local — do NOT commit secrets).

# === Required ===
DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full
PAYLOAD_SECRET=replace-with-your-payload-secret-min-32-chars
NEXT_PUBLIC_SITE_URL=https://theagilenest.com
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_WITH_YOUR_TOKEN
PAYLOAD_CONFIG_PATH=src/payload.config.ts
NODE_ENV=production

# === Recommended API protection ===
CRON_SECRET=replace-with-random-string
BACKUP_SECRET=replace-with-random-string
EXPORT_SECRET=replace-with-random-string
CACHE_SECRET=replace-with-random-string
HEALTH_SECRET=replace-with-random-string

# === Optional email ===
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=contact@theagilenest.com
# RESEND_API_KEY=re_xxxxx
